#!/usr/bin/env bash

LONGOPTS=help,opt:
SHORTOPTS=ho:
PROGRAM_NAME=$(basename "$0")

source getopt.bash

while true; do
    opt=$1
    shift
    case "$opt" in
        -h|--help)
            echo "Usage: $0 [-h|--help] [-o|--opt]"
            exit 0
            ;;
        -o|--opt)
            option_value="$1"
            shift
            ;;
        --)
            break
            ;;
        *)
            echo "Error: getopt was configured incorrectly." >&2
            echo "Error: Contact the author of '$0'" >&2
            exit 3
            ;;
    esac
done

# do stuff
echo "option was set to: $option_value"
echo "non-option arguments: $@"
